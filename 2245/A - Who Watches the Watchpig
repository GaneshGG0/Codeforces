#include <bits/stdc++.h>
using namespace std;
 
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    cout.tie(nullptr);
    int tcase;
    cin >> tcase;
    while (tcase--) {
        int n,k;
        string s;
        cin>>n>>k;
        cin>>s;
        if(n<2*k) {
            cout<<-1<<"
";
            continue; 
        }
        int f=0;
        for (int i=0;i<k;++i) {
            if(s[i]!='R') {
                f++;
            }
        }
        for (int j=n-k;j<n;++j) {
            if(s[j]!='L') {
                f++;
            }
        }
        cout<<f<<endl; 
    }
    return 0;
}